{
  "name": "lexguard-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node --watch-path=server server/index.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "test": "node --test tests/*.test.mjs",
    "start": "node server/index.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
